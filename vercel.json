{
  "version": 2,
  "name": "quiz-frances-charlie",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/passe-compose-quiz",
      "dest": "/passe-compose-quiz.html"
    },
    {
      "src": "/passe-compose-quiz.html",
      "dest": "/passe-compose-quiz.html"
    },
    {
      "src": "/animais",
      "dest": "/animais.html"
    },
    {
      "src": "/animais.html",
      "dest": "/animais.html"
    },
    {
      "src": "/partes-do-corpo",
      "dest": "/partes-do-corpo.html"
    },
    {
      "src": "/partes-do-corpo.html",
      "dest": "/partes-do-corpo.html"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
